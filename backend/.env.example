NODE_ENV=production
PORT=5000

# MongoDB Atlas connection string (DO NOT commit real credentials)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<dbName>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# CORS
# For mobile apps, "*" is fine if you don't use cookies.
# If you want to restrict: comma-separated list like "https://admin.example.com,https://member.example.com"
CORS_ORIGIN=*

# Gmail SMTP (optional; use an App Password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: app name in emails
APP_NAME=DineIN

# MongoDB backup to Google Drive (rclone)
# Example remote name from `rclone config`: gdrive
RCLONE_REMOTE=gdrive
# Folder on Drive where backups are stored
RCLONE_REMOTE_DIR=MongoBackups
# Local backup folder on server/PC
MONGO_BACKUP_LOCAL_DIR=./backups
# Optional database name override; if empty, inferred from MONGODB_URI
MONGO_BACKUP_DB_NAME=
# Keep local .archive.gz files for N days
MONGO_BACKUP_LOCAL_RETENTION_DAYS=14
# Delete remote backups older than N days
MONGO_BACKUP_REMOTE_RETENTION_DAYS=30
# Enable automatic daily backup at 12:00 AM (server local time)
MONGO_BACKUP_AUTO_ENABLED=false
# Optional absolute paths (use when tools are not in PATH, common on Windows)
# MONGODUMP_PATH=C:\Program Files\MongoDB\Tools\100\bin\mongodump.exe
# RCLONE_PATH=C:\Program Files\rclone\rclone.exe
